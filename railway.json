{
  "$schema": "https://railway.app/json-schema/railway-schema.json",
  "build": {
    "builder": "dockerfile",
    "context": "backend"
  },
  "deploy": {
    "startCommand": "uvicorn backend.main:app --host 0.0.0.0 --port $PORT"
  },
  "env": {
    "ENV": "production",
    "DEBUG": "false",
    "LOG_LEVEL": "INFO",
    "ALGORITHM": "HS256",
    "ACCESS_TOKEN_EXPIRE_MINUTES": "30",
    "API_FOOTBALL_ENDPOINT": "https://api-football-v1.p.rapidapi.com",
    "FBREF_USE_CACHE": "true"
  }
}
