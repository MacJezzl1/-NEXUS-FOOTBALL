# NEXUS FOOTBALL — Environment Configuration
# Copy this file to .env and fill in your values

# ━━━━━ API KEYS ━━━━━
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_openai_key
TOGETHER_API_KEY=your_together_key
COHERE_API_KEY=your_cohere_key
RAPIDAPI_KEY=your_rapidapi_key

# ━━━━━ DATABASE ━━━━━
DATABASE_URL=postgresql://user:password@localhost:5432/nexus_football
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_key

# ━━━━━ REDIS ━━━━━
REDIS_URL=redis://localhost:6379

# ━━━━━ JWT & SECURITY ━━━━━
SECRET_KEY=your_super_secret_key_change_this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ━━━━━ ENVIRONMENT ━━━━━
ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ━━━━━ CORS ━━━━━
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# ━━━━━ FOOTBALL DATA SOURCES ━━━━━
API_FOOTBALL_ENDPOINT=https://api-football-v1.p.rapidapi.com
FBREF_USE_CACHE=true

# ━━━━━ SENTRY (MONITORING) ━━━━━
SENTRY_DSN=your_sentry_dsn

# ━━━━━ FRONTEND ━━━━━
REACT_APP_API_URL=http://localhost:8000
REACT_APP_ENV=development
